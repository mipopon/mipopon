{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "automerge": true,
  "automergeType": "pr",
  "lockFileMaintenance": {
    "automerge": true,
    "matchCurrentVersion": "!/^0/",
    "matchUpdateTypes": ["minor", "patch"],
  },
  "minor": {
    "automerge": true
  },
  "patch": {
    "automerge": true
  },
  "pin": {
    "automerge": true
  },
  "extends": [
    "config:recommended", ":dependencyDashboard"
  ]
}
